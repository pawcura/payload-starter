# Database
DATABASE_URI=mongodb://127.0.0.1/your-database-name

# Payload
PAYLOAD_SECRET=YOUR_SECRET_HERE
# Shared secret for headless apps reading posts via REST (Bearer or X-CMS-Read-Key).
# Generate: openssl rand -base64 32
CMS_READ_API_KEY=YOUR_CMS_READ_API_KEY

# Site
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
SITE_NAME=Payload Starter
SITE_DESCRIPTION=A Payload CMS starter template.
NEXT_PUBLIC_COPYRIGHT_HOLDER=My Site

# S3 Storage (required)
S3_API=YOUR_S3_ENDPOINT
S3_BUCKET=YOUR_S3_BUCKET_NAME
S3_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET_ACCESS_KEY
# S3_PUBLIC_URL=YOUR_S3_PUBLIC_URL  # Optional — if not set, media is served through the app

# Email (optional — Resend)
# RESEND_API_KEY=YOUR_RESEND_API_KEY
# EMAIL_FROM_ADDRESS=noreply@yourdomain.com
# EMAIL_FROM_NAME=My Site
